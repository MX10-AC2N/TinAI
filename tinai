#!/bin/bash
# ══════════════════════════════════════════════════════════════════
#  tinai – CLI de gestion TinAI v2
#  Usage : tinai <status|logs|update|model|stop|start|restart|help>
# ══════════════════════════════════════════════════════════════════

TINAI_VERSION="2.0.0"
COMPOSE_DIR="${TINAI_DIR:-TINAI_DIR_PLACEHOLDER}"
COMPOSE_FILE="$COMPOSE_DIR/docker-compose.yml"
ENV_FILE="${COMPOSE_DIR}/../.env"

# Charger le .env si présent (ports configurables)
if [ -f "$ENV_FILE" ]; then
    set -a; source "$ENV_FILE"; set +a
elif [ -f "$COMPOSE_DIR/.env" ]; then
    set -a; source "$COMPOSE_DIR/.env"; set +a
fi

# Valeurs par défaut (identiques à install.sh)
PORT_LLAMA="${PORT_LLAMA:-8081}"
PORT_WEBUI="${PORT_WEBUI:-3000}"
PORT_SILLYTAVERN="${PORT_SILLYTAVERN:-8008}"
PORT_CODE="${PORT_CODE:-8080}"
PORT_OPENFANG="${PORT_OPENFANG:-4200}"
PORT_EMBEDDINGS="${PORT_EMBEDDINGS:-8084}"
PORT_QDRANT="${PORT_QDRANT:-6333}"
PORT_VISION="${PORT_VISION:-8085}"
PORT_COMFYUI="${PORT_COMFYUI:-7860}"
PORT_SWAP="${PORT_SWAP:-11434}"
PORT_CADDY="${PORT_CADDY:-80}"
PORT_FILEBROWSER="${PORT_FILEBROWSER:-8083}"
MODELS_DIR="${MODELS_DIR:-./models}"
LLAMA_MEM_LIMIT="${LLAMA_MEM_LIMIT:-5.5g}"
LLAMA_CTX_SIZE="${LLAMA_CTX_SIZE:-8192}"
LLAMA_THREADS="${LLAMA_THREADS:-4}"
LLAMA_GPU_LAYERS="${LLAMA_GPU_LAYERS:-0}"
LLAMA_HF_REPO="${LLAMA_HF_REPO:-bartowski/Qwen2.5-Coder-3B-Instruct-GGUF}"
LLAMA_HF_FILE="${LLAMA_HF_FILE:-Qwen2.5-Coder-3B-Instruct-Q5_K_M.gguf}"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

check_compose() {
    if [ ! -f "$COMPOSE_FILE" ]; then
        echo -e "${RED}❌ docker-compose.yml introuvable dans $COMPOSE_DIR${RESET}"
        echo "   Lance d'abord : ./install.sh"
        exit 1
    fi
}

cmd_status() {
    check_compose
    echo -e "${BOLD}🧠 TinAI v${TINAI_VERSION} – État des services${RESET}"
    echo "════════════════════════════════════════════"
    cd "$COMPOSE_DIR"

    declare -A PORTS=(
        [tinai-llama]="${PORT_LLAMA}"
        [tinai-webui]="${PORT_WEBUI}"
        [tinai-sillytavern]="${PORT_SILLYTAVERN}"
        [tinai-code]="${PORT_CODE}"
        [tinai-aider]=""
        [tinai-openfang]="${PORT_OPENFANG}"
        [tinai-embeddings]="${PORT_EMBEDDINGS}"
        [tinai-qdrant]="${PORT_QDRANT}"
        [tinai-vision]="${PORT_VISION}"
        [tinai-comfyui]="${PORT_COMFYUI}"
        [tinai-swap]="${PORT_SWAP}"
        [tinai-caddy]="${PORT_CADDY}"
        [tinai-filebrowser]="${PORT_FILEBROWSER}"
    )

    declare -A LABELS=(
        [tinai-llama]="llama-server  "
        [tinai-webui]="Open WebUI    "
        [tinai-sillytavern]="SillyTavern   "
        [tinai-code]="Code-Server   "
        [tinai-aider]="Aider         "
        [tinai-openfang]="OpenFang      "
        [tinai-embeddings]="Embeddings    "
        [tinai-qdrant]="Qdrant RAG    "
        [tinai-vision]="Vision VL     "
        [tinai-comfyui]="ComfyUI       "
        [tinai-swap]="llama-swap    "
        [tinai-caddy]="Caddy         "
        [tinai-filebrowser]="Filebrowser   "
    )

    for container in "${!LABELS[@]}"; do
        STATE=$(docker inspect --format='{{.State.Status}}' "$container" 2>/dev/null || echo "absent")
        [ "$STATE" = "absent" ] && continue

        PORT="${PORTS[$container]}"
        LABEL="${LABELS[$container]}"

        if [ "$STATE" = "running" ]; then
            if [ -n "$PORT" ] && curl -sSf --max-time 2 "http://127.0.0.1:$PORT/" >/dev/null 2>&1; then
                echo -e "  ${GREEN}✅${RESET} ${LABEL} → ${CYAN}http://localhost:${PORT}${RESET}"
            elif [ -n "$PORT" ]; then
                echo -e "  ${YELLOW}⏳${RESET} ${LABEL} → démarrage en cours (port $PORT)"
            else
                echo -e "  ${GREEN}✅${RESET} ${LABEL} → actif"
            fi
        else
            echo -e "  ${RED}❌${RESET} ${LABEL} → $STATE"
        fi
    done

    echo ""
    echo -e "${BOLD}💾 Ressources :${RESET}"
    docker stats --no-stream --format \
        "  {{.Name}}\tCPU: {{.CPUPerc}}\tMEM: {{.MemUsage}}" 2>/dev/null \
        | grep "tinai-" | column -t
}

cmd_logs() {
    check_compose
    cd "$COMPOSE_DIR"
    SERVICES=$(docker compose ps --services 2>/dev/null)

    if [ -z "$1" ]; then
        if command -v gum &>/dev/null; then
            SVC=$(echo "$SERVICES" | gum choose --header "Quel service ?")
        else
            echo "Services disponibles :"
            echo "$SERVICES" | nl -ba
            read -rp "Numéro : " NUM
            SVC=$(echo "$SERVICES" | sed -n "${NUM}p")
        fi
    else
        SVC="$1"
    fi

    [ -z "$SVC" ] && exit 0
    echo -e "${CYAN}📋 Logs de $SVC (Ctrl+C pour quitter)${RESET}"
    docker compose logs -f --tail=100 "$SVC"
}

cmd_update() {
    check_compose
    cd "$COMPOSE_DIR"
    echo -e "${BOLD}🔄 Mise à jour des images TinAI...${RESET}"
    docker compose pull
    echo -e "${GREEN}✅ Images à jour – redémarrage...${RESET}"
    docker compose up -d --remove-orphans
    echo -e "${GREEN}✅ TinAI v2 mis à jour !${RESET}"
}

cmd_model() {
    check_compose
    cd "$COMPOSE_DIR"
    echo -e "${BOLD}🤖 Sélection du modèle llama-server${RESET}"
    echo "════════════════════════════════════════════"

    # Modèle actif chargé depuis .env (ou défaut)
    echo -e "  Modèle actuel : ${CYAN}${LLAMA_HF_FILE}${RESET}"
    echo ""

    declare -A MODELS=(
        ["Qwen2.5-Coder-3B  – coding  – 2.2 GB (défaut)"]="--hf-repo bartowski/Qwen2.5-Coder-3B-Instruct-GGUF --hf-file Qwen2.5-Coder-3B-Instruct-Q5_K_M.gguf"
        ["Qwen2.5-Coder-7B  – coding  – 4.8 GB"]="--hf-repo bartowski/Qwen2.5-Coder-7B-Instruct-GGUF --hf-file Qwen2.5-Coder-7B-Instruct-Q4_K_M.gguf"
        ["LLaVA-Phi-3-mini  – vision  – 2.2 GB"]="--hf-repo xtuner/llava-phi-3-mini-gguf --hf-file llava-phi-3-mini-f16.gguf"
        ["Mistral-7B        – général – 4.1 GB"]="--hf-repo bartowski/Mistral-7B-Instruct-v0.3-GGUF --hf-file Mistral-7B-Instruct-v0.3-Q4_K_M.gguf"
        ["Phi-3.5-mini      – léger   – 2.2 GB"]="--hf-repo bartowski/Phi-3.5-mini-instruct-GGUF --hf-file Phi-3.5-mini-instruct-Q4_K_M.gguf"
        ["DeepSeek-Coder-1.3B – micro – 0.8 GB"]="--hf-repo bartowski/deepseek-coder-1.3b-instruct-GGUF --hf-file deepseek-coder-1.3b-instruct-Q5_K_M.gguf"
    )

    MODEL_NAMES=("${!MODELS[@]}")

    if command -v gum &>/dev/null; then
        SELECTED=$(printf '%s\n' "${MODEL_NAMES[@]}" | gum choose --header "Choisis un modèle :")
    else
        echo "Modèles disponibles :"
        for i in "${!MODEL_NAMES[@]}"; do
            echo "  $((i+1))) ${MODEL_NAMES[$i]}"
        done
        read -rp "Numéro : " NUM
        SELECTED="${MODEL_NAMES[$((NUM-1))]}"
    fi

    [ -z "$SELECTED" ] && exit 0
    ARGS="${MODELS[$SELECTED]}"
    FULL_CMD="$ARGS --host 0.0.0.0 --port 8081 --ctx-size ${LLAMA_CTX_SIZE} --threads ${LLAMA_THREADS} --n-gpu-layers ${LLAMA_GPU_LAYERS} --jinja"

    echo -e "${YELLOW}🔄 Remplacement de llama-server...${RESET}"
    docker rm -f tinai-llama 2>/dev/null || true

    NETWORK=$(docker network ls --filter "name=$(basename "$COMPOSE_DIR")" --format "{{.Name}}" | head -1)

    docker run -d \
        --name tinai-llama \
        --network "$NETWORK" \
        -p "${PORT_LLAMA}:8081" \
        -v "$(pwd)/${MODELS_DIR}:/models" \
        --memory "${LLAMA_MEM_LIMIT}" \
        ghcr.io/ggml-org/llama.cpp:server \
        $FULL_CMD

    echo -e "${GREEN}✅ Modèle changé : $SELECTED${RESET}"
    echo -e "   Accès : ${CYAN}http://localhost:${PORT_LLAMA}/v1/models${RESET}"
}

cmd_stop() {
    check_compose
    cd "$COMPOSE_DIR"
    echo -e "${YELLOW}⏹️  Arrêt de TinAI...${RESET}"
    docker compose down
    echo -e "${GREEN}✅ TinAI arrêté${RESET}"
}

cmd_start() {
    check_compose
    cd "$COMPOSE_DIR"
    echo -e "${GREEN}▶️  Démarrage de TinAI...${RESET}"
    docker compose up -d
    echo -e "${GREEN}✅ TinAI démarré${RESET}"
    sleep 3
    cmd_status
}

cmd_restart() {
    cmd_stop
    sleep 2
    cmd_start
}

cmd_help() {
    echo -e "${BOLD}🧠 TinAI v${TINAI_VERSION} – CLI${RESET}"
    echo ""
    echo "Usage : tinai <commande> [options]"
    echo ""
    echo "Commandes :"
    echo -e "  ${CYAN}status${RESET}          État de tous les services + ressources"
    echo -e "  ${CYAN}logs [service]${RESET}  Logs en direct (menu si service omis)"
    echo -e "  ${CYAN}update${RESET}          Met à jour toutes les images Docker"
    echo -e "  ${CYAN}model${RESET}           Change le modèle LLM à chaud"
    echo -e "  ${CYAN}start${RESET}           Démarre tous les services"
    echo -e "  ${CYAN}stop${RESET}            Arrête tous les services"
    echo -e "  ${CYAN}restart${RESET}         Redémarre tous les services"
    echo ""
    echo "Exemples :"
    echo "  tinai status"
    echo "  tinai logs llama-server"
    echo "  tinai model"
    echo "  tinai update"
}

case "${1:-help}" in
    status)  cmd_status    ;;
    logs)    cmd_logs "$2" ;;
    update)  cmd_update    ;;
    model)   cmd_model     ;;
    start)   cmd_start     ;;
    stop)    cmd_stop      ;;
    restart) cmd_restart   ;;
    *)       cmd_help      ;;
esac