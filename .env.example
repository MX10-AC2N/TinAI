# ══════════════════════════════════════════════════════════════════
#  TinAI v5 – Configuration
#  cp .env.example .env  →  édite selon tes besoins
# ══════════════════════════════════════════════════════════════════

# ── Répertoires ───────────────────────────────────────────────────
MODELS_DIR=./models
WEBUI_DATA_DIR=./data/webui
OPENFANG_DATA_DIR=./data/openfang

# ── Ports exposés ────────────────────────────────────────────────
PORT_LLAMA=8081       # llama-server API + WebUI intégrée
PORT_OPENFANG=4200    # OpenFang dashboard + API
PORT_WEBUI=3000       # Open WebUI (si profil webui actif)

# ══════════════════════════════════════════════════════════════════
#  MODÈLE
#  Place ton .gguf dans ./models/ OU configure HF_REPO + HF_FILE
#  → llama-server télécharge automatiquement au 1er démarrage
# ══════════════════════════════════════════════════════════════════

LLAMA_HF_REPO=Qwen/Qwen3-1.7B-GGUF
LLAMA_HF_FILE=qwen3-1.7b-q5_k_m.gguf
#   q4_k_m.gguf  → ~1.2 GB · rapide        (< 4 GB RAM)
#   q5_k_m.gguf  → ~1.4 GB · équilibré     ← défaut
#   q8_0.gguf    → ~1.9 GB · haute qualité

# Alias affiché dans les clients OpenAI-compatible
LLAMA_MODEL_ALIAS=qwen3-1.7b

# ── Paramètres llama.cpp ─────────────────────────────────────────
LLAMA_CTX_SIZE=8192   # Contexte tokens
LLAMA_THREADS=4       # Threads CPU (= nb cœurs physiques)
LLAMA_GPU_LAYERS=0    # 0 = CPU only | -1 = full GPU
LLAMA_N_PARALLEL=1    # Requêtes parallèles

# ── Ressources ───────────────────────────────────────────────────
MEM_LIMIT=6g          # RAM max conteneur llama
WEBUI_MEM_LIMIT=3g    # RAM max Open WebUI (si profil webui actif)

# ══════════════════════════════════════════════════════════════════
#  SÉCURITÉ ⚠️ — CHANGER avant exposition réseau !
#  openssl rand -hex 32
# ══════════════════════════════════════════════════════════════════
TINAI_API_KEY=sk-tinai                  # ⚠️ CHANGER
WEBUI_SECRET_KEY=tinai-secret-change-me # ⚠️ CHANGER (profil webui)

# ══════════════════════════════════════════════════════════════════
#  IMAGES (pour déploiement depuis GHCR)
# ══════════════════════════════════════════════════════════════════
# TINAI_IMAGE=ghcr.io/mx10-ac2n/tinai:latest
LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server
WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main-slim

# ══════════════════════════════════════════════════════════════════
#  OPENFANG — Canaux de messagerie (optionnel)
# ══════════════════════════════════════════════════════════════════
# TELEGRAM_BOT_TOKEN=123456:ABCdef...
# DISCORD_BOT_TOKEN=MTxxxxxxxx...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-1-...

# ── LLM providers externes (pour OpenFang) ───────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
