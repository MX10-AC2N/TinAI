# ══════════════════════════════════════════════════════════════════
#  TinAI v3 – Configuration
#  cp .env.example .env  →  édite selon tes besoins
#  cp .env.example .env  →  edit as needed
# ══════════════════════════════════════════════════════════════════

# ── Répertoires / Directories ─────────────────────────────────────
MODELS_DIR=./models
WEBUI_DATA_DIR=./data/webui
OPENFANG_DATA_DIR=./data/openfang

# ── Ports exposés / Exposed ports ────────────────────────────────
PORT_WEBUI=3000       # Open WebUI
PORT_OPENFANG=4200    # OpenFang agents dashboard
PORT_LLAMA=8081       # llama-server (OpenAI-compatible API)

# ══════════════════════════════════════════════════════════════════
#  MODÈLE / MODEL
#  Choisir UNE des configurations ci-dessous
#  Choose ONE of the configurations below
# ══════════════════════════════════════════════════════════════════

# ── Qwen3-1.7B (défaut / default) — ~3 GB RAM ────────────────────
LLAMA_HF_REPO=Qwen/Qwen3-1.7B-GGUF
LLAMA_HF_FILE=qwen3-1.7b-q5_k_m.gguf
#   q4_k_m.gguf  → ~1.2 GB · rapide / fast  (< 4 GB RAM)
#   q5_k_m.gguf  → ~1.4 GB · équilibré / balanced  ← défaut
#   q8_0.gguf    → ~1.9 GB · haute qualité / high quality

# ── Phi-3 Mini 4K (Microsoft) — ~3 GB RAM ────────────────────────
# LLAMA_HF_REPO=microsoft/Phi-3-mini-4k-instruct-gguf
# LLAMA_HF_FILE=Phi-3-mini-4k-instruct-q4.gguf

# ── Mistral 7B Instruct — ~5 GB RAM ──────────────────────────────
# LLAMA_HF_REPO=TheBloke/Mistral-7B-Instruct-v0.2-GGUF
# LLAMA_HF_FILE=mistral-7b-instruct-v0.2.Q4_K_M.gguf

# ── Gemma 2 2B Instruct — ~3 GB RAM ──────────────────────────────
# LLAMA_HF_REPO=bartowski/gemma-2-2b-it-GGUF
# LLAMA_HF_FILE=gemma-2-2b-it-Q5_K_M.gguf

# ── Modèle personnalisé / Custom model ───────────────────────────
# Place ton .gguf dans ./models/ puis configure :
# LLAMA_HF_REPO=MonOrg/MonRepo-GGUF
# LLAMA_HF_FILE=mon-modele-q5_k_m.gguf

# ── Paramètres llama.cpp ─────────────────────────────────────────
LLAMA_CTX_SIZE=8192   # Contexte tokens – réduis si peu de RAM / reduce if low RAM
LLAMA_THREADS=4       # Threads CPU (= nb cœurs physiques / physical cores)
LLAMA_GPU_LAYERS=0    # 0 = CPU only │ -1 = tout GPU / full GPU

# Optimisations CPU avancées / Advanced CPU optimizations
# (décommente si ton CPU supporte AVX2 / uncomment if your CPU supports AVX2)
# LLAMA_EXTRA_ARGS=--cpu-mask 0xFF

# ── Ressources / Resources ───────────────────────────────────────
MEM_LIMIT=6g          # Limite RAM conteneur / Container RAM limit

# ══════════════════════════════════════════════════════════════════
#  SÉCURITÉ / SECURITY ⚠️
#  CHANGER OBLIGATOIREMENT avant exposition réseau !
#  MUST CHANGE before any network exposure!
#
#  Générer des clés sécurisées / Generate secure keys:
#    openssl rand -hex 32
# ══════════════════════════════════════════════════════════════════
TINAI_API_KEY=sk-tinai                  # ⚠️ CHANGER / CHANGE THIS
WEBUI_SECRET_KEY=tinai-secret-change-me # ⚠️ CHANGER / CHANGE THIS

# ══════════════════════════════════════════════════════════════════
#  OPENFANG — Canaux de messagerie / Messaging channels (optionnel)
#  Voir https://openfang.sh/docs/channel-adapters
# ══════════════════════════════════════════════════════════════════
# TELEGRAM_BOT_TOKEN=123456:ABCdef...
# DISCORD_BOT_TOKEN=MTxxxxxxxx...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-1-...

# ── LLM providers externes (optionnel — pour OpenFang) ───────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...

# ══════════════════════════════════════════════════════════════════
#  GHCR — Pour le workflow de publication / For the publish workflow
# ══════════════════════════════════════════════════════════════════
# TINAI_IMAGE=ghcr.io/ton-username/tinai:latest
