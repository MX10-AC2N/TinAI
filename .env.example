# =============================================
# TinAI v7 – .env.example
# Copie ce fichier en .env et modifie selon tes besoins
# =============================================

# ── Clé API commune (utilisée par tous les services) ──
TINAI_API_KEY=sk-tinai-secret-key-change-me-in-production

# ── Ports des services ──
PORT_LLAMA=8081
PORT_OPENFANG=4200
PORT_LITELLM=4000
PORT_HERMES=4201
PORT_WEBUI=3000

# ── Chemins de données et modèles ──
MODELS_DIR=./models
OPENFANG_DATA_DIR=./data/openfang
HERMES_DATA_DIR=./data/hermes
WEBUI_DATA_DIR=./data/webui

# ── Configuration llama.cpp ──
LLAMA_HF_REPO=Qwen/Qwen3-1.7B-GGUF
LLAMA_HF_FILE=Qwen3-1.7B-Q5_K_M.gguf
LLAMA_CTX_SIZE=8192
LLAMA_N_PARALLEL=1
LLAMA_THREADS=4
LLAMA_GPU_LAYERS=0
MEM_LIMIT=6g

# ── LiteLLM ──
LITELLM_MASTER_KEY=sk-tinai-litellm

# ── Open WebUI ──
WEBUI_SECRET_KEY=super-secret-key-change-me-in-production
WEBUI_AUTH=False

# ── Hermès Agent (optionnel – le wizard le configure automatiquement) ──
HERMES_LLM_BASE_URL=http://llama:8080/v1