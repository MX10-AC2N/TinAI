# ══════════════════════════════════════════════════════════════════
#  TinAI v2 – Configuration
#  Copie ce fichier en .env et modifie les valeurs selon tes besoins
#  cp .env.example .env
# ══════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────
#  RÉPERTOIRES
#  Chemins des dossiers montés dans les conteneurs.
#  Chemins absolus ou relatifs (relatifs au dossier TinAI/).
# ────────────────────────────────────────────────────────────────

# Modèles GGUF téléchargés automatiquement
MODELS_DIR=./models

# Tes projets (montés dans Code-Server, Aider et Filebrowser)
PROJECTS_DIR=./projects

# Modèles et sorties ComfyUI
COMFYUI_MODELS_DIR=./comfyui/models
COMFYUI_OUTPUT_DIR=./comfyui/output

# Config OpenFang (openfang.toml généré automatiquement)
OPENFANG_CONFIG_DIR=./openfang-config

# ────────────────────────────────────────────────────────────────
#  PORTS EXPOSÉS
#  Format : PORT_HOST (le port interne du conteneur ne change pas)
# ────────────────────────────────────────────────────────────────

# llama-server – API LLM principale (OpenAI-compatible)
PORT_LLAMA=8081

# Open WebUI – frontend chat + RAG
PORT_WEBUI=3000

# SillyTavern – frontend créatif
PORT_SILLYTAVERN=8008

# Code-Server – VS Code web
PORT_CODE=8080

# OpenFang – agents autonomes
PORT_OPENFANG=4200

# Embeddings – nomic-embed-text (RAG)
PORT_EMBEDDINGS=8084

# Qdrant – base vectorielle REST API
PORT_QDRANT=6333
# Qdrant gRPC (optionnel, nécessaire pour certains clients)
PORT_QDRANT_GRPC=6334

# Vision – LLaVA-Phi-3-mini (analyse d'images)
PORT_VISION=8085

# ComfyUI – génération d'images
PORT_COMFYUI=7860

# llama-swap – switch de modèles à chaud (compatible Ollama API)
PORT_SWAP=11434

# Caddy – reverse proxy HTTP
PORT_CADDY=80
# Caddy HTTPS (nécessite un domaine + DNS)
PORT_CADDY_HTTPS=443

# Filebrowser – explorateur de fichiers web
PORT_FILEBROWSER=8083

# ────────────────────────────────────────────────────────────────
#  AUTHENTIFICATION
# ────────────────────────────────────────────────────────────────

# Mot de passe Code-Server (VS Code web)
CODE_PASSWORD=changezmoi123

# Clé API partagée entre les services (valeur libre, pas envoyée vers l'extérieur)
TINAI_API_KEY=sk-tinai

# ────────────────────────────────────────────────────────────────
#  MODÈLES LLM
# ────────────────────────────────────────────────────────────────

# Modèle principal (llama-server)
# Exemples :
#   bartowski/Qwen2.5-Coder-3B-Instruct-GGUF  /  Qwen2.5-Coder-3B-Instruct-Q5_K_M.gguf  (~2.2 GB)
#   bartowski/Qwen2.5-Coder-7B-Instruct-GGUF  /  Qwen2.5-Coder-7B-Instruct-Q4_K_M.gguf  (~4.8 GB)
#   bartowski/Mistral-7B-Instruct-v0.3-GGUF   /  Mistral-7B-Instruct-v0.3-Q4_K_M.gguf   (~4.1 GB)
#   bartowski/Phi-3.5-mini-instruct-GGUF       /  Phi-3.5-mini-instruct-Q4_K_M.gguf       (~2.2 GB)
LLAMA_HF_REPO=bartowski/Qwen2.5-Coder-3B-Instruct-GGUF
LLAMA_HF_FILE=Qwen2.5-Coder-3B-Instruct-Q5_K_M.gguf

# Modèle Aider (doit correspondre au modèle chargé dans llama-server)
AIDER_MODEL=qwen-coder-3b

# ────────────────────────────────────────────────────────────────
#  PARAMÈTRES LLM
# ────────────────────────────────────────────────────────────────

# Taille du contexte llama-server (tokens) – augmenter si RAM suffisante
LLAMA_CTX_SIZE=8192

# Nombre de threads CPU pour llama-server
# Recommandé : nombre de cœurs physiques (pas hyperthreading)
LLAMA_THREADS=4

# Couches GPU déchargées (0 = CPU only, -1 = toutes si GPU disponible)
LLAMA_GPU_LAYERS=0

# Limite mémoire llama-server
LLAMA_MEM_LIMIT=5.5g

# Taille du contexte embeddings
EMBED_CTX_SIZE=2048

# Threads CPU embeddings
EMBED_THREADS=2

# Limite mémoire embeddings
EMBED_MEM_LIMIT=1g

# Taille du contexte vision (LLaVA)
VISION_CTX_SIZE=4096

# Threads CPU vision
VISION_THREADS=4

# Limite mémoire vision
VISION_MEM_LIMIT=4g

# Limite mémoire ComfyUI
COMFYUI_MEM_LIMIT=4g
