# ══════════════════════════════════════════════════════════════════
#  TinAI v3 – Configuration
#  cp .env.example .env  →  édite selon tes besoins
# ══════════════════════════════════════════════════════════════════

# ── Répertoires ──────────────────────────────────────────────────
MODELS_DIR=./models
WEBUI_DATA_DIR=./data/webui
OPENFANG_DATA_DIR=./data/openfang

# ── Ports exposés ────────────────────────────────────────────────
PORT_WEBUI=3000       # Open WebUI
PORT_OPENFANG=4200    # OpenFang agents
PORT_LLAMA=8081       # llama-server (API OpenAI-compatible)

# ── Modèle Qwen3-1.7B ────────────────────────────────────────────
# Options de quantization disponibles sur HuggingFace :
#   qwen3-1.7b-q4_k_m.gguf  (~1.2 GB – recommandé si < 4 GB RAM)
#   qwen3-1.7b-q5_k_m.gguf  (~1.4 GB – meilleur équilibre)
#   qwen3-1.7b-q8_0.gguf    (~1.9 GB – haute qualité)
LLAMA_HF_REPO=Qwen/Qwen3-1.7B-GGUF
LLAMA_HF_FILE=qwen3-1.7b-q5_k_m.gguf

# ── Paramètres llama.cpp ─────────────────────────────────────────
LLAMA_CTX_SIZE=8192   # Taille contexte (tokens) – réduis si peu de RAM
LLAMA_THREADS=4       # Threads CPU (= nb cœurs physiques recommandé)
LLAMA_GPU_LAYERS=0    # 0 = CPU only │ -1 = tout sur GPU si disponible

# ── Ressources ───────────────────────────────────────────────────
MEM_LIMIT=6g          # Limite mémoire du conteneur Docker

# ── Sécurité ─────────────────────────────────────────────────────
TINAI_API_KEY=sk-tinai                  # Clé API llama-server & OpenFang
WEBUI_SECRET_KEY=tinai-secret-change-me # Clé secrète Open WebUI (JWT)
