# ══════════════════════════════════════════════════════════════════
#  TinAI – OpenFang configuration
#  Copier vers /data/openfang/openfang.toml pour personnaliser.
#  Les variables d'env (OPENAI_API_KEY, etc.) ont priorité sur ce fichier.
# ══════════════════════════════════════════════════════════════════

[server]
host = "0.0.0.0"
port = 4200

[llm]
# llama-server local — remplace par une URL distante si besoin
base_url = "http://localhost:8081/v1"
api_key  = "sk-tinai"   # = TINAI_API_KEY dans .env
# L'alias est dérivé automatiquement du nom du fichier GGUF
# ex: qwen3-1.7b-q5_k_m.gguf → model = "qwen3-1.7b"
model    = "qwen3-1.7b"

[agents]
dir = "/data/openfang/agents"

# ── Providers LLM externes (optionnel) ───────────────────────────
# Décommente et configure si tu veux utiliser des APIs distantes en parallèle.
# Ces valeurs sont surchargées par les variables d'env du docker-compose.
#
# [providers.anthropic]
# api_key = ""  # → ANTHROPIC_API_KEY
#
# [providers.openai]
# api_key = ""  # → OPENAI_API_KEY
#
# [providers.groq]
# api_key = ""  # → GROQ_API_KEY
