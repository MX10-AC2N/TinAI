# ══════════════════════════════════════════════════════════════════
#  OpenFang – Configuration
#  Ce fichier est généré automatiquement par install.sh.
#  Pour le personnaliser, modifie le .env AVANT de lancer install.sh,
#  ou édite directement openfang-config/openfang.toml après installation.
# ══════════════════════════════════════════════════════════════════

[server]
# Adresse d'écoute du serveur OpenFang
host = "0.0.0.0"
# Port exposé (configurable via PORT_OPENFANG dans .env)
port = 4200

[llm]
# URL de l'API LLM locale (llama-server dans le réseau Docker)
base_url = "http://llama-server:8081/v1"
# Clé API partagée (configurable via TINAI_API_KEY dans .env)
api_key = "sk-tinai"
# Modèle à utiliser (doit correspondre à l'alias chargé dans llama-server)
model = "qwen-coder-3b"

[agents]
# Répertoire des agents embarqués dans l'image OpenFang
dir = "/opt/openfang/agents"
